# PrintBuddy — Production .env
# Auf VPS speichern unter: /opt/printbuddy/.env
# NIEMALS in Git committen!

# Django
SECRET_KEY=HIER_MINDESTENS_50_ZUFAELLIGE_ZEICHEN_EINTRAGEN
DEBUG=False
LOCAL_DEV=False
MOCK_GPU=False
ALLOWED_HOSTS=datemyhobby.com,www.datemyhobby.com

# Admin URL (custom — niemals /admin/)
ADMIN_URL=pb-manage/

# Datenbank (PostgreSQL auf localhost)
DATABASE_URL=postgres://printbuddy:PASSWORT_HIER@localhost:5432/printbuddy

# Redis (localhost only)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Stripe (Live-Keys für Production)
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Printful
PRINTFUL_API_KEY=REPLACE_ME

# RunPod
RUNPOD_API_KEY=REPLACE_ME
RUNPOD_ENDPOINT_ID=REPLACE_ME
RUNPOD_UPSCALE_ENDPOINT=REPLACE_ME

# Vast.ai (Fallback)
VASTAI_API_KEY=REPLACE_ME

# Etsy
ETSY_API_KEY=REPLACE_ME
ETSY_API_SECRET=REPLACE_ME
ETSY_REDIRECT_URI=https://datemyhobby.com/etsy/callback/

# Email (Mailgun oder ähnlich)
EMAIL_HOST=smtp.mailgun.org
EMAIL_HOST_USER=REPLACE_ME
EMAIL_HOST_PASSWORD=REPLACE_ME
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@datemyhobby.com

# NAS
NAS_BASE_PATH=/mnt/agency_nas
